# === AI Provider (default: groq) ===
AI_PROVIDER=groq

# Groq — free, no credit card, ~14,400 req/day
# Sign up: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini — free, 250 req/day (optional alternative)
# Sign up: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# xAI Grok — $25 free credit, then paid (optional alternative)
# Sign up: https://console.x.ai
XAI_API_KEY=

# === News Data ===
# Finnhub — free tier
# Sign up: https://finnhub.io/register
FINNHUB_API_KEY=your_finnhub_api_key_here

# === Watchlist Settings ===
MAX_WATCHLIST_SCANS_PER_DAY=10
